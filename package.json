{
  "name": "screenshotr-extension",
  "version": "0.1.0",
  "description": "One-keystroke screenshot capture with automatic organization",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build:dev": "wxt build --mode development",
    "dev:firefox": "wxt --browser firefox",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^4.1.3",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "idb": "^8.0.3"
  }
}
